[Unit]
Description=TonPI GPIO Control Service
After=network.target

[Service]
Type=simple
User=tonpi
WorkingDirectory=/home/tonpi/TonPI
EnvironmentFile=-/home/tonpi/TonPI/.env
ExecStart=/usr/bin/python3 gpio-control/read_gpio.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target